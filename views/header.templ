      "@type": "Question",
      "name": "How do I use CypherGoat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Simply enter the amount and select the coins you want to swap. CypherGoat will automatically find the best rate for you and allows you to perform the swap securely."
      }
    },
    {
      "@type": "Question",
      "name": "Are there any fees for using CypherGoat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cyphergoat has no access to your funds. All swaps are handled by the exchange of your choice. We do not charge any extra fee above the standard fee of the exchanges and network transaction fees."
      }
    },
    {
      "@type": "Question",
      "name": "What cryptocurrencies are supported?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We currently support 60+ coins and 15+ exchanges, covering all major cryptocurrencies and many altcoins."
      }
    },
    {
      "@type": "Question",
      "name": "Is CypherGoat safe to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. CypherGoat does not get access to your funds at any stage of the swap. We are simply an aggregator interface. We are also the only exchange aggregator that is fully open source, which means that anyone can audit our code at any time."
      }
    },
    {
      "@type": "Question",
      "name": "What is the CypherGoat Shield program?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The CypherGoat Shield is our user protection program that guarantees you'll receive your funds or get reimbursed if an exchange fails to complete your transaction or holds your funds due to KYC issues. Look for the Shield icon next to exchange names to see the coverage amount."
      }
    }
  ]
}
</script>
		</body>
	</html>
}

func generateBlogPostJsonLD(post *BlogPostData) string {
	jsonLD := map[string]interface{}{
		"@context":    "https://schema.org",
		"@type":       "BlogPosting",
		"headline":    post.Title,
		"description": post.Description,
		"image":       post.Image,
		"author": map[string]interface{}{
			"@type": "Person",
			"name":  post.Author,
		},
		"publisher": map[string]interface{}{
			"@type": "Organization",
			"name":  "CypherGoat",
			"logo": map[string]interface{}{
				"@type": "ImageObject",
				"url":   "https://cyphergoat.com/static/icons/cg-notext.svg",
			},
		},
		"datePublished": post.Date,
		"mainEntityOfPage": map[string]interface{}{
			"@type": "WebPage",
			"@id":   fmt.Sprintf("https://cyphergoat.com/blog/%s", post.Slug),
		},
	}

	jsonBytes, err := json.MarshalIndent(jsonLD, "", "  ")
	if err != nil {
		return "<script type=\"application/ld+json\">{}</script>"
	}

	return "<script type=\"application/ld+json\">\n" + string(jsonBytes) + "\n</script>"
}

templ BlogHeader(post *BlogPostData) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<link rel="icon" type="image/x-icon" href="/static/icons/favicon/light/favicon.ico" media="(prefers-color-scheme: light)"/>
			<link rel="icon" type="image/x-icon" href="/static/icons/favicon/dark/favicon.ico" media="(prefers-color-scheme: dark)"/>
			<link rel="icon" type="image/png" sizes="32x32" href="/static/icons/favicon/light/favicon-32x32.png" media="(prefers-color-scheme: light)"/>
			<link rel="icon" type="image/png" sizes="32x32" href="/static/icons/favicon/dark/favicon-32x32.png" media="(prefers-color-scheme: dark)"/>
			<link rel="icon" type="image/png" sizes="16x16" href="/static/icons/favicon/light/favicon-16x16.png" media="(prefers-color-scheme: light)"/>
			<link rel="icon" type="image/png" sizes="16x16" href="/static/icons/favicon/dark/favicon-16x16.png" media="(prefers-color-scheme: dark)"/>
			<link rel="icon" href="/favicon.ico" sizes="any"/>
			<link rel="apple-touch-icon" sizes="180x180" href="/static/icons/favicon/light/apple-touch-icon.png"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<link href="/static/tailwind.css?v=202508145" rel="stylesheet"/>
			<link href="/static/styles.css?v=202508145" rel="stylesheet"/>
			<script src="/static/htmx.min.js"></script>
			<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer"/>
			<title>{ post.Title } | CypherGoat</title>
			<meta name="title" content={ post.Title + " | CypherGoat" }/>
			<meta name="description" content={ post.Description }/>
			<meta name="keywords" content={ strings.Join(post.Tags, ", ") + ", crypto, exchange, cryptocurrency" }/>
			<meta name="author" content={ post.Author }/>
			if post.IssueSlug != "" {
				<link rel="canonical" href={ fmt.Sprintf("https://cyphergoat.com/this-week-in-monero/%s", post.IssueSlug) }/>
			} else {
				<link rel="canonical" href={ fmt.Sprintf("https://cyphergoat.com/blog/%s", post.Slug) }/>
			}
			<meta property="og:type" content="article"/>
			if post.IssueSlug != "" {
				<meta property="og:url" content={ fmt.Sprintf("https://cyphergoat.com/this-week-in-monero/%s", post.IssueSlug) }/>
			} else {
				<meta property="og:url" content={ fmt.Sprintf("https://cyphergoat.com/blog/%s", post.Slug) }/>
			}
			<meta property="og:title" content={ post.Title + " | CypherGoat" }/>
			<meta property="og:description" content={ post.Description }/>
			if post.Image != "" {
				<meta property="og:image" content={ post.Image }/>
			} else {
				<meta property="og:image" content="https://cyphergoat.com/static/icons/cg-notext-light.png"/>
				<meta property="og:image:type" content="image/png"/>
				<meta property="og:image:width" content="1200"/>
				<meta property="og:image:height" content="630"/>
				<meta property="og:image:alt" content="CypherGoat - Crypto Exchange Aggregator"/>
			}
			<meta property="twitter:card" content="summary_large_image"/>
			if post.IssueSlug != "" {
				<meta property="twitter:url" content={ fmt.Sprintf("https://cyphergoat.com/this-week-in-monero/%s", post.IssueSlug) }/>
			} else {
				<meta property="twitter:url" content={ fmt.Sprintf("https://cyphergoat.com/blog/%s", post.Slug) }/>
			}
			<meta property="twitter:title" content={ post.Title + " | CypherGoat Blog" }/>
			<meta property="twitter:description" content={ post.Description }/>
			if post.Image != "" {
				<meta property="twitter:image" content={ post.Image }/>
			} else {
				<meta property="twitter:image" content="https://cyphergoat.com/static/icons/cg-notext-dark.png"/>
				<meta name="twitter:image:alt" content="CypherGoat - Crypto Exchange Aggregator"/>
			}
			<meta property="article:published_time" content={ post.Date }/>
			<meta property="article:author" content={ post.Author }/>
			for _, tag := range post.Tags {
				<meta property="article:tag" content={ tag }/>
			}
			@templ.Raw(generateBlogPostJsonLD(post))
			<script defer data-domain="cyphergoat.com" src="https://stats.cyphergoat.com/js/script.outbound-links.tagged-events.js"></script>
			<script>window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }</script>
			@SharedNavbarHead()
		</head>
		<body class="bg-[#0b0d14] text-gray-100 antialiased">
			@SharedNavbar()
			{ children... }
		</body>
	</html>
}

