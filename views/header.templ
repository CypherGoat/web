templ SharedNavbarHead() {
	<script>
        document.addEventListener("DOMContentLoaded", function () {
            const menuToggle = document.getElementById("menu-toggle");
            const navMenu = document.getElementById("nav-menu");

            if (!menuToggle || !navMenu) {
                return;
            }

            const setExpanded = function (expanded) {
                menuToggle.setAttribute("aria-expanded", expanded ? "true" : "false");
            };

            const closeMenu = function () {
                navMenu.classList.remove("nav-active");
                setExpanded(false);
            };

            menuToggle.addEventListener("click", function () {
                const isOpen = navMenu.classList.toggle("nav-active");
                setExpanded(isOpen);
            });

            document.addEventListener("click", function (e) {
                if (!navMenu.contains(e.target) && !menuToggle.contains(e.target) && navMenu.classList.contains("nav-active")) {
                    closeMenu();
                }
            });

            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape" && navMenu.classList.contains("nav-active")) {
                    closeMenu();
                }
            });

            window.addEventListener("resize", function () {
                if (window.innerWidth >= 1024) {
                    closeMenu();
                }
            });

            const menuLinks = navMenu.querySelectorAll("a");
            menuLinks.forEach(link => {
                link.addEventListener("click", function() {
                    if (window.innerWidth < 1024) {
                        closeMenu();
                    }
                });
            });

            setExpanded(false);
        });
    </script>
	<style>
        .site-header {
            position: sticky;
            top: 0;
            z-index: 60;
            padding: 0.85rem 0;
            background: rgba(11, 13, 20, 0.84);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(16px);
        }

        .site-nav-shell {
            max-width: 92rem;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        .site-nav-frame {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            min-height: 5.35rem;
            padding: 0.25rem 0;
            position: relative;
        }

        .logo-link {
            display: inline-flex;
            align-items: center;
            gap: 1.2rem;
            color: #ffffff;
            text-decoration: none;
        }

        .logo-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 4.85rem;
            height: 4.85rem;
            border-radius: 1.45rem;
            background: rgba(255, 255, 255, 0.045);
            border: 1px solid rgba(255, 255, 255, 0.07);
        }

        .logo-img {
            width: 3.3rem;
            height: 3.3rem;
            transition: opacity 0.18s ease, transform 0.18s ease;
        }

        .logo-copy {
            display: flex;
            flex-direction: column;
            line-height: 1;
        }

        .logo-title {
            font-size: 1.85rem;
            font-weight: 700;
            letter-spacing: -0.045em;
        }

        .logo-subtitle {
            display: none;
        }

        .logo-link:hover .logo-img {
            opacity: 0.88;
            transform: scale(0.97);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .menu-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.7rem;
            height: 2.7rem;
            border-radius: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: transparent;
            color: #9aa2b2;
            transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
        }

        .menu-toggle:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.03);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .menu-toggle:focus-visible,
        .nav-primary-link:focus-visible,
        .nav-cta:focus-visible {
            outline: 2px solid rgba(255, 255, 255, 0.18);
            outline-offset: 2px;
        }

        .nav-menu {
            display: flex;
            align-items: center;
            gap: 0.55rem;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.1rem;
        }

        .nav-primary-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.45rem;
            padding: 0.62rem 0.88rem;
            border-radius: 0.7rem;
            color: #98a1b1;
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 550;
            letter-spacing: 0.01em;
            transition: color 0.18s ease, background 0.18s ease;
        }

        .nav-primary-link:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.03);
        }

        .nav-cta {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.45rem;
            padding: 0.62rem 0.95rem;
            border-radius: 0.75rem;
            background: transparent;
            color: #dbe1ea;
            text-decoration: none;
            font-size: 0.86rem;
            font-weight: 600;
            letter-spacing: 0.01em;
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: background 0.18s ease, transform 0.18s ease, border-color 0.18s ease, color 0.18s ease;
        }

        .nav-cta:hover {
            background: rgba(255, 255, 255, 0.03);
            border-color: rgba(255, 255, 255, 0.12);
            color: #ffffff;
        }

        @media (max-width: 1023px) {
            .site-nav-shell {
                padding: 0 1rem;
            }

            .site-nav-frame {
                min-height: 4.6rem;
                padding: 0.2rem 0;
            }

            .logo-badge {
                width: 4.1rem;
                height: 4.1rem;
                border-radius: 1.25rem;
            }

            .logo-img {
                width: 2.8rem;
                height: 2.8rem;
            }

            .logo-title {
                font-size: 1.55rem;
            }

            #nav-menu {
                position: absolute;
                top: calc(100% + 0.55rem);
                left: 0;
                right: 0;
                display: flex !important;
                flex-direction: column;
                align-items: stretch;
                gap: 0.85rem;
                padding: 0.85rem;
                border-radius: 1rem;
                background: rgba(14, 17, 25, 0.98);
                border: 1px solid rgba(255, 255, 255, 0.06);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.28);
                opacity: 0;
                transform: translateY(-10px);
                pointer-events: none;
                transition: opacity 0.18s ease, transform 0.18s ease;
                z-index: 80;
            }

            #nav-menu.nav-active {
                opacity: 1;
                transform: translateY(0);
                pointer-events: auto;
            }

            #nav-menu .nav-links {
                flex-direction: column;
                align-items: stretch;
                gap: 0.35rem;
                padding: 0;
                background: transparent;
                border: 0;
            }

            #nav-menu .nav-primary-link,
            #nav-menu .nav-cta {
                width: 100%;
                justify-content: flex-start;
                border-radius: 0.95rem;
            }

            #nav-menu .nav-primary-link {
                min-height: 2.75rem;
                padding: 0.8rem 0.9rem;
                background: rgba(255, 255, 255, 0.02);
            }

            #nav-menu .nav-primary-link:hover {
                background: rgba(255, 255, 255, 0.04);
            }

            #nav-menu .nav-cta {
                justify-content: center;
            }
        }

        @media (min-width: 1024px) {
            .menu-toggle {
                display: none;
            }
        }
    </style>
	<script>
        document.documentElement.classList.add("js-enabled");
        document.body.classList.add("js-enabled");
    </script>
}

templ SharedNavbar() {
	<header class="site-header">
		<nav class="site-nav-shell">
			<div class="site-nav-frame">
				<a class="logo-link" href="/" aria-label="CypherGoat home">
					<span class="logo-badge">
						<img src="/static/icons/cg-notext.svg" width="30" height="30" class="logo-img" alt="CypherGoat logo"/>
					</span>
					<span class="logo-copy">
						<span class="logo-title">CypherGoat</span>
					</span>
				</a>
				<div class="nav-right">
					<button id="menu-toggle" class="menu-toggle" aria-label="Toggle navigation" aria-controls="nav-menu" aria-expanded="false" type="button">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
						</svg>
					</button>
					<div id="nav-menu" class="nav-menu">
						<div class="nav-links">
							<a class="nav-primary-link" href="/">Home</a>
							<a class="nav-primary-link" href="/exchanges">Exchanges</a>
							<a class="nav-primary-link" href="/affiliate">Affiliate</a>
							<a class="nav-primary-link" href="/this-week-in-monero" title="This Week In Monero">TWIM</a>
						</div>
						<a class="nav-cta" href="/">Swap</a>
					</div>
				</div>
			</div>
		</nav>
	</header>
}

